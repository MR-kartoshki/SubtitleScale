{
  "schemaVersion": 1,
  "id": "subtitlescale",
  "version": "${version}",
  "name": "SubtitleScale",
  "description": "Scales vanilla subtitles.",
  "authors": [
    "Iaske"
  ],
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.example.subtitlescale.SubtitleScaleClient"
    ],
    "modmenu": [
      "com.example.subtitlescale.modmenu.SubtitleScaleModMenu"
    ]
  },
  "mixins": [
    "subtitlescale.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "minecraft": ">=1.21.9 <=1.21.11",
    "fabric-api": "*",
    "cloth-config2": ">=21.11.153"
  },
  "suggests": {
    "modmenu": "*"
  }
}
